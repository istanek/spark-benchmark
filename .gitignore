# Quick-run prompts persisted via `spark-bench quick --save` or the
# TUI's Quick → "Save as suite?" affordance. Kept out of the repo so
# personal one-shots don't end up under version control alongside the
# shipped templates.
examples/custom-tests/quick-saved/

# Long-context haystacks — large public-domain corpora fetched on demand
# via scripts/fetch_haystacks.sh. Provenance lives in the suite fixture;
# the bytes stay out of the repo. The directory's README is kept.
data/long_context/haystacks/*.txt

# Local secrets / overrides
.env
.env.local
*.pem
*.key
